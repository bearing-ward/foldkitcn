{
  "name": "foldkitcn",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "devtools-mcp": "foldkit-devtools-mcp",
    "build": "vite build",
    "preview": "vite preview",
    "docs:prerender": "bun run scripts/prerender.ts",
    "docs:live-preview-gaps": "bun run scripts/report-docs-live-preview-gaps.ts",
    "docs:search": "pagefind",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "oxlint",
    "check": "ultracite check --disable-nested-config",
    "fix": "ultracite fix",
    "foldkitcn": "bun run src/installer/entry.ts",
    "registry:check": "bun run scripts/check-registry.ts",
    "registry:build": "bun run scripts/build-registry.ts",
    "origin:resolve": "bun run scripts/resolve-origin-url.ts",
    "origin:components:status": "bun run scripts/registry-component-progress.ts status",
    "origin:components:next": "bun run scripts/registry-component-progress.ts next",
    "origin:components:write": "bun run scripts/registry-component-progress.ts write",
    "origin:components:check": "bun run scripts/registry-component-progress.ts check",
    "parity:check": "bun run scripts/parity-dry-run.ts",
    "parity:contracts": "bun run scripts/report-public-parity-contracts.ts",
    "parity:contracts:write": "bun run scripts/report-public-parity-contracts.ts --write",
    "parity:origin:shadcn": "bun run scripts/parity-origin-shadcn.ts",
    "parity:workbench": "bun run scripts/parity-workbench.ts"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.88",
    "@floating-ui/dom": "^1.7.6",
    "@foldkit/devtools": "^0.127.0",
    "@foldkit/ui": "^0.127.0",
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.88",
    "foldkit": "^0.127.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@base-ui/react": "1.5.0",
    "@floating-ui/utils": "^0.2.11",
    "@foldkit/devtools-mcp": "^0.13.1",
    "@foldkit/oxlint-plugin": "^0.3.0",
    "@foldkit/vite-plugin": "^0.10.0",
    "@playwright/test": "^1.61.1",
    "@tabler/icons-react": "^3.31.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "happy-dom": "^20.10.6",
    "lucide-react": "0.474.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "pagefind": "^1.5.2",
    "react": "19.2.3",
    "react-day-picker": "^9.7.0",
    "react-dom": "19.2.3",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
