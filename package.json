{
  "name": "foldkitcn",
  "version": "0.1.0",
  "homepage": "https://bearing-ward.github.io/foldkitcn/",
  "repository": {
    "type": "git",
    "url": "https://github.com/bearing-ward/foldkitcn.git"
  },
  "type": "module",
  "imports": {
    "#live-examples": "./src/live-examples.ts",
    "#parity-foldkit-runner": "./tests/parity/fixtures/foldkit/shadcn/runner.ts",
    "#parity-origin-runner": "./tests/parity/fixtures/origin/shadcn/runner.ts",
    "#registry/schema": "./src/registry/schema.ts",
    "#registry/*/examples": "./src/registry/*/examples.ts",
    "#registry/*/workflow": "./src/registry/*/workflow.ts",
    "#registry/*": "./src/registry/*/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "devtools-mcp": "foldkit-devtools-mcp",
    "build": "vite build",
    "preview": "vite preview",
    "docs:prerender": "bun run scripts/prerender.ts",
    "docs:live-preview-gaps": "bun run scripts/report-docs-live-preview-gaps.ts",
    "docs:search": "pagefind",
    "typecheck": "bun run typecheck:source && bun run typecheck:tests",
    "typecheck:bounded": "bun run typecheck",
    "typecheck:source": "bun run typecheck:live-examples && bun run typecheck:parity-origin && bun run typecheck:parity-foldkit && bun run typecheck:app-shell && bun run typecheck:source-support && bun run typecheck:scripts-registry && bun run typecheck:scripts-docs && bun run typecheck:scripts-parity-capture && bun run typecheck:scripts-parity-workbench && bun run typecheck:scripts-parity-contracts",
    "typecheck:tests": "bun run typecheck:story-test && bun run typecheck:test-root && bun run typecheck:test-data && bun run typecheck:test-scene && bun run typecheck:test-base-ui-a-m && bun run typecheck:test-base-ui-n-z && bun run typecheck:test-shadcn-a-b && bun run typecheck:test-shadcn-c && bun run typecheck:test-shadcn-d-i && bun run typecheck:test-shadcn-j-r && bun run typecheck:test-shadcn-s-z && bun run typecheck:test-scripts && bun run typecheck:test-parity && bun run typecheck:test-e2e",
    "typecheck:app-shell": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.app-shell.json",
    "typecheck:live-examples": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.live-examples.json",
    "typecheck:parity-origin": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.parity-origin.json",
    "typecheck:parity-foldkit": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.parity-foldkit.json",
    "typecheck:source-support": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.source-support.json",
    "typecheck:scripts-registry": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.scripts-registry.json",
    "typecheck:scripts-docs": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.scripts-docs.json",
    "typecheck:scripts-parity-capture": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.scripts-parity-capture.json",
    "typecheck:scripts-parity-workbench": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.scripts-parity-workbench.json",
    "typecheck:scripts-parity-contracts": "NODE_OPTIONS=--max-old-space-size=4096 tsc --project tsconfig.scripts-parity-contracts.json",
    "typecheck:story-test": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.story-test.json",
    "typecheck:test-root": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-root.json",
    "typecheck:test-data": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-data.json",
    "typecheck:test-scene": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-scene.json",
    "typecheck:test-base-ui-a-m": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-base-ui-a-m.json",
    "typecheck:test-base-ui-n-z": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-base-ui-n-z.json",
    "typecheck:test-shadcn-a-b": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-shadcn-a-b.json",
    "typecheck:test-shadcn-c": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-shadcn-c.json",
    "typecheck:test-shadcn-d-i": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-shadcn-d-i.json",
    "typecheck:test-shadcn-j-r": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-shadcn-j-r.json",
    "typecheck:test-shadcn-s-z": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-shadcn-s-z.json",
    "typecheck:test-scripts": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-scripts.json",
    "typecheck:test-parity": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-parity.json",
    "typecheck:test-e2e": "NODE_OPTIONS=--max-old-space-size=2048 tsc --project tsconfig.test-e2e.json",
    "format": "oxfmt --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "oxlint",
    "check": "ultracite check --disable-nested-config",
    "fix": "ultracite fix",
    "foldkitcn": "bun run src/installer/entry.ts",
    "registry:check": "bun run scripts/check-registry.ts",
    "registry:build": "bun run scripts/build-registry.ts",
    "origin:resolve": "bun run scripts/resolve-origin-url.ts",
    "origin:components:status": "bun run scripts/registry-component-progress.ts status",
    "origin:components:next": "bun run scripts/registry-component-progress.ts next",
    "origin:components:write": "bun run scripts/registry-component-progress.ts write",
    "origin:components:check": "bun run scripts/registry-component-progress.ts check",
    "parity:check": "bun run scripts/parity-dry-run.ts",
    "parity:contracts": "bun run scripts/report-public-parity-contracts.ts",
    "parity:contracts:write": "bun run scripts/report-public-parity-contracts.ts --write",
    "parity:origin:shadcn": "bun run scripts/parity-origin-shadcn.ts",
    "parity:workbench": "bun run scripts/parity-workbench.ts"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.88",
    "@floating-ui/dom": "^1.7.6",
    "@foldkit/devtools": "^0.127.0",
    "@foldkit/ui": "^0.127.0",
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.88",
    "foldkit": "^0.127.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@base-ui/react": "1.5.0",
    "@effect/platform-node": "4.0.0-beta.88",
    "@floating-ui/utils": "^0.2.11",
    "@foldkit/devtools-mcp": "^0.13.1",
    "@foldkit/oxlint-plugin": "^0.3.0",
    "@foldkit/vite-plugin": "^0.10.0",
    "@playwright/test": "^1.61.1",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-table": "^8.9.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "happy-dom": "^20.10.6",
    "lucide-react": "0.474.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "pagefind": "^1.5.2",
    "react": "19.2.3",
    "react-day-picker": "^9.7.0",
    "react-dom": "19.2.3",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.88"
  }
}
