  "deviations": [
    {
      "id": "shadcn-input-group-local-class-helper",
      "summary": "CVA is replaced by Effect Schema addon alignment and button size options plus explicit Foldkit attribute helpers.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable Foldkit source must stay Effect-native and must not import React or CVA."
    },
    {
      "id": "shadcn-input-group-local-icons-and-rtl",
      "summary": "Icon examples and RTL labels use local inline SVGs and deterministic strings instead of origin icon packages and language selector runtime.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable source cannot depend on lucide-react, @tabler/icons-react, or the origin app language selector."
    },
    {
      "id": "shadcn-input-group-toast-and-clipboard-deferred",
      "summary": "Toast and copy-to-clipboard behavior is represented as static controls until local command/toast foundations are available.",
      "required": true,
      "status": "accepted",
      "rationale": "Side effects belong in parent Foldkit messages and commands; this stateless helper must not import sonner or React clipboard hooks."
    },
    {
      "id": "shadcn-input-group-static-textarea-sizing",
      "summary": "Textarea examples use static Foldkit textarea sizing instead of react-textarea-autosize.",
      "required": true,
      "status": "accepted",
      "rationale": "Autosize behavior is not required for the installable Input Group contract and would need a separate local behavior foundation."
    }
  ]
