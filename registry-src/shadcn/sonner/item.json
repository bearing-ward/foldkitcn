  "deviations": [
    {
      "id": "shadcn-sonner-local-icons-and-theme-attribute",
      "summary": "The wrapper uses an explicit theme attribute and local inline SVG icons instead of next-themes and lucide-react.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable Foldkit source cannot depend on the upstream Sonner runtime, next-themes, or lucide-react. The local theme attribute and icons preserve the visible notification surface and keep the wrapper installable."
    }
  ]
