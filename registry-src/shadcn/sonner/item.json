        "specifier": "clsx",
        "classification": "allowed-runtime",
        "target": "npm:clsx",
        "reason": "Provided through the local utils/cn registry dependency."
      },
      {
        "specifier": "tailwind-merge",
        "classification": "allowed-runtime",
        "target": "npm:tailwind-merge",
        "reason": "Provided through the local utils/cn registry dependency."
      }
    ],
    "development": [
      {
        "specifier": "sonner",
        "classification": "dev-or-fixture-only",
