  "deviations": [
    {
      "id": "sidebar-controlled-state-boundary",
      "summary": "Open, collapsed, mobile, and active item state are explicit parent-controlled facts instead of a hidden React context or cookie-backed provider.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit keeps state in the model and avoids hidden browser storage or ambient React context."
    },
    {
      "id": "sidebar-no-hidden-global-shortcut-listener",
      "summary": "The installable source does not install a hidden global keyboard listener for cmd/ctrl+b.",
      "required": true,
      "status": "accepted",
      "rationale": "Global listeners hidden in view code are forbidden here. Keyboard shortcut facts must be explicit model or command boundary events."
    }
  ],
  "distinguishes": "Foldkit-native shadcn sidebar shell built from local shell, menu, tooltip, collapsible, sheet, avatar, and input primitives with explicit parent-controlled state.",
