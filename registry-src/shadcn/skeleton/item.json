    {
      "id": "shadcn-skeleton-local-card-shell",
      "summary": "Card example uses fixture-local static Card shell classes instead of an installable shadcn Card component.",
      "required": true,
      "status": "accepted",
      "rationale": "This batch intentionally does not add shadcn/card as an installable registry item. The local Card shell preserves the origin DOM slots and base-nova classes used by the Skeleton Card example."
    },
    {
      "id": "shadcn-skeleton-local-rtl-data",
      "summary": "RTL example uses local constants instead of the origin language-selector runtime dependency.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable source cannot depend on the origin app language selector. Local RTL constants preserve the default rendered direction while fixture aliases keep the origin evidence bundleable."
    }
