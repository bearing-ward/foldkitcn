  "deviations": [
    {
      "id": "shadcn-avatar-static-dropdown-shell",
      "summary": "Dropdown example uses a fixture-local static shell instead of an installable shadcn Dropdown Menu component.",
      "required": true,
      "status": "accepted",
      "rationale": "This batch intentionally does not add shadcn/dropdown-menu. The static shell preserves the Avatar trigger and fixture coverage without adding runtime dependencies."
    },
    {
      "id": "shadcn-avatar-local-rtl-data",
      "summary": "RTL example uses local Arabic constants instead of the origin language-selector runtime dependency.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable source cannot depend on the origin app language selector. Local Arabic constants preserve the default RTL rendered output while fixture aliases keep the origin evidence bundleable."
    },
    {
      "id": "shadcn-avatar-local-icons",
      "summary": "Icon examples use local inline SVGs instead of lucide-react.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable source cannot include lucide-react. The inline Plus SVG preserves the visible icon examples as fixture-local markup."
    }
  ]
