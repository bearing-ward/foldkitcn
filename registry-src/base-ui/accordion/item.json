  "deviations": [
    {
      "id": "base-ui-accordion-model-owned-value-state",
      "summary": "Open item value state is a model-owned input and trigger presses emit value-change facts instead of mutating internal component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit preserves unidirectional data flow. Consumers update their model in response to AccordionValueChange payloads."
    },
    {
      "id": "base-ui-accordion-explicit-transition-measurement",
      "summary": "Transition status and panel dimensions are explicit inputs rather than DOM-measured internal state.",
      "required": true,
      "status": "accepted",
      "rationale": "Base UI measures panel dimensions for animated panels. Foldkit registry primitives stay pure and reuse the plan 028 explicit measurement convention."
    },
    {
      "id": "base-ui-accordion-loop-focus-no-op",
      "summary": "The deprecated loopFocus option is accepted as source-evidence API shape but intentionally has no keyboard behavior.",
      "required": true,
      "status": "accepted",
      "rationale": "Pinned Base UI Accordion deprecates loopFocus and orientation-driven roving focus after the APG update. The Foldkit helper preserves orientation data attributes but does not implement arrow-key focus movement."
    }
  ]
