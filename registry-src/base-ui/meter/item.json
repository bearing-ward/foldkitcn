  "deviations": [
    {
      "id": "explicit-label-id",
      "summary": "Meter label association uses an explicit labelId option instead of React-managed context.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit render helpers are stateless and do not use hidden mutable context; callers provide a stable labelId so root aria-labelledby and label id remain explicit and deterministic."
    },
    {
      "id": "foldkit-render-helper",
      "summary": "Meter composition uses a Foldkit toView callback instead of Base UI's React render prop.",
      "required": true,
      "status": "accepted",
      "rationale": "The registry item exposes Foldkit Html attributes for each named part and lets callers compose them through toView, preserving the part contract without React render/asChild interop."
    }
  ],
