  "deviations": [
    {
      "id": "base-ui-collapsible-model-owned-open-state",
      "summary": "Open state is a model-owned input and trigger presses emit open-change facts instead of mutating internal component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit preserves unidirectional data flow. Consumers update their model in response to CollapsibleOpenChange payloads."
    },
    {
      "id": "base-ui-collapsible-consumer-provided-panel-id",
      "summary": "ARIA controls relationships use caller-provided ids instead of generated React ids.",
      "required": true,
      "status": "accepted",
      "rationale": "Installable render helpers are pure and deterministic. Consumers provide stable root or panel ids when they need aria-controls wiring."
    },
    {
      "id": "base-ui-collapsible-transition-measurement-input",
      "summary": "Transition status and panel dimensions are explicit inputs rather than DOM-measured internal state.",
      "required": true,
      "status": "accepted",
      "rationale": "Base UI measures scroll dimensions for animated panels. Foldkit registry primitives stay pure; shared animation measurement belongs in a future runtime policy or consumer command."
    }
  ],
