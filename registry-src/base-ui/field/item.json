  "deviations": [
    {
      "id": "base-ui-field-model-owned-validation",
      "summary": "Validation is represented by explicit Schema tagged states instead of Base UI React's internal validation hooks and Form context.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit keeps validation facts in the consuming model. Field exposes pure validity helpers and attributes so update owns validation transitions."
    },
    {
      "id": "base-ui-field-explicit-ids",
      "summary": "Label, control, description, and error relationships use explicit or field-derived ids instead of React context registration.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit render helpers are stateless. Deterministic ids preserve accessible relationships without hidden mutable registration state."
    },
    {
      "id": "base-ui-field-static-origin-fixture",
      "summary": "Parity origin fixture uses static source-derived markup for deterministic Field output.",
      "required": true,
      "status": "accepted",
      "rationale": "The React origin's dynamic validation machinery is evidence for attributes and relationships; the Foldkit port intentionally keeps state outside the component."
    }
  ]
