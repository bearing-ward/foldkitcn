    {
      "id": "base-ui-avatar-modeled-loading-status",
      "summary": "Image loading is caller-owned Foldkit model state instead of an internal React Image effect.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit installable source must remain pure and unidirectional. The helper exposes image load/error message hooks and derives rendered parts from the caller's modeled ImageLoadingStatus."
    },
    {
      "id": "base-ui-avatar-explicit-delay-state",
      "summary": "Fallback delay visibility is represented by explicit delayStatus state instead of an internal timer.",
      "required": true,
      "status": "accepted",
      "rationale": "Timers belong in Foldkit commands or subscriptions owned by an app model. The installable helper preserves fallback visibility semantics without hidden lifecycle state."
    }
