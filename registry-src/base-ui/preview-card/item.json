  "deviations": [
    {
      "id": "base-ui-preview-card-model-owned-open-state",
      "summary": "Open state and active trigger identity are model-owned inputs; trigger and popup interactions emit open-change facts instead of mutating hidden component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit preserves unidirectional data flow. Consumers decide whether hover, focus, press, delay, and disabled facts update their model."
    },
    {
      "id": "base-ui-preview-card-delay-as-model-facing-facts",
      "summary": "Delay and closeDelay are exposed as deterministic attributes and open-change facts rather than hidden timers.",
      "required": true,
      "status": "accepted",
      "rationale": "The installable primitive remains pure. Shared timer or subscription behavior can be added later through a reusable Foldkit abstraction."
    },
    {
      "id": "base-ui-preview-card-deterministic-placement-attributes",
      "summary": "Placement is represented through deterministic side, align, offset, collision, positioner, viewport, and arrow attributes without performing DOM measurement or collision flipping.",
      "required": true,
      "status": "accepted",
      "rationale": "Measured collision handling depends on runtime geometry and should be shared with Popover and Tooltip rather than implemented ad hoc in Preview Card."
    }
  ]
