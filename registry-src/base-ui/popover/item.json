  "deviations": [
    {
      "id": "base-ui-popover-model-owned-open-state",
      "summary": "Open state is a model-owned input and user interactions emit open-change facts instead of mutating internal component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit preserves unidirectional data flow. Consumers update their model and return command helpers in response to PopoverOpenChange payloads."
    },
    {
      "id": "base-ui-popover-command-facing-focus-effects",
      "summary": "Focus handoff and focus restoration are exposed as explicit Command helpers rather than hidden inside render helpers.",
      "required": true,
      "status": "accepted",
      "rationale": "Popover side effects must stay at Foldkit's Command boundary. The installable view remains pure and deterministic."
    },
    {
      "id": "base-ui-popover-deterministic-placement-attributes",
      "summary": "Placement is represented through deterministic side, align, offset, collision, positioner, and arrow attributes without performing DOM measurement or collision flipping.",
      "required": true,
      "status": "accepted",
      "rationale": "Real collision handling depends on measured geometry and should be added through a shared measurement service, not an ad hoc render helper side effect."
    }
  ]
