  "deviations": [
    {
      "id": "base-ui-navigation-menu-model-owned-value-state",
      "summary": "Open state is derived from the model-owned active item value; trigger, list, link, backdrop, and Escape interactions emit typed value-change facts instead of mutating internal component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit preserves unidirectional data flow and keeps Navigation Menu value/open state in the consuming model."
    },
    {
      "id": "base-ui-navigation-menu-command-facing-focus-effects",
      "summary": "Focus handoff and restoration are exposed as Commands instead of being hidden inside render helpers.",
      "required": true,
      "status": "accepted",
      "rationale": "Navigation Menu side effects must stay at Foldkit's Command boundary. The installable view remains pure and deterministic."
    },
    {
      "id": "base-ui-navigation-menu-deterministic-placement-and-sizing",
      "summary": "Positioner, popup, viewport, content, arrow, collision, activation-direction, and sizing surfaces are represented as deterministic attributes without DOM measurement, ResizeObserver, MutationObserver, or collision flipping.",
      "required": true,
      "status": "accepted",
      "rationale": "Measured geometry and auto-sizing belong behind a shared runtime service, not inside an installable render helper."
    }
  ],
