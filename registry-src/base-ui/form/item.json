  "deviations": [
    {
      "id": "base-ui-form-model-owned-validation",
      "summary": "Validation and submission state are represented by explicit model-owned fields and typed payloads instead of Base UI React's internal Form context.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit keeps validation facts and side effects in update/commands. The Form helper reports submit/reset payloads and invalid field names without mutating application state."
    },
    {
      "id": "base-ui-form-no-imperative-actions-ref",
      "summary": "The React actionsRef validate API is not implemented as an imperative Form method.",
      "required": true,
      "status": "accepted",
      "rationale": "Imperative validation conflicts with Foldkit's Elm-style architecture. Consumers trigger validation through messages and update transitions."
    },
    {
      "id": "base-ui-form-static-origin-fixture",
      "summary": "Parity origin fixture uses static source-derived markup for deterministic Form and Field output.",
      "required": true,
      "status": "accepted",
      "rationale": "The installable source must not import upstream React. Static fixtures preserve the pinned form root, noValidate default, Field structure, and state attributes while the origin source remains checked in under repos/base-ui."
    }
  ]
