  "deviations": [
    {
      "id": "base-ui-scroll-area-static-origin-fixture",
      "summary": "Base UI parity uses a static source-derived origin fixture for root, viewport, content, scrollbar, thumb, corner, data attributes, and CSS variable footprints.",
      "required": true,
      "status": "accepted",
      "rationale": "Origin Scroll Area relies on live layout measurement and ResizeObserver. The static fixture keeps origin evidence independent of the Foldkit implementation while pinning the deterministic source-derived measured states used by parity."
    },
    {
      "id": "base-ui-scroll-area-model-owned-measurement-state",
      "summary": "Overflow, edge, scrolling, hover, thumb, and corner state are supplied or derived from deterministic metric inputs instead of hidden component state.",
      "required": true,
      "status": "accepted",
      "rationale": "Foldkit render helpers stay pure. Browser measurement belongs behind commands or future shared measurement infrastructure rather than an ad hoc ResizeObserver inside installable source."
    },
    {
      "id": "base-ui-scroll-area-deterministic-scroll-geometry",
      "summary": "Track press and thumb drag scroll math is exposed as pure helpers that accept measured sizes.",
      "required": true,
      "status": "accepted",
      "rationale": "The origin mutates scrollTop and scrollLeft from DOM events. The Foldkit implementation exposes equivalent deterministic calculations so consuming update/command code can own effects."
    }
  ],
  "distinguishes": "Foldkit-native Base UI Scroll Area primitive preserving root, viewport, content, scrollbar, thumb, corner, orientation, overflow, scrolling, hover, and data-attribute contracts through deterministic model-owned state and geometry helpers.",
