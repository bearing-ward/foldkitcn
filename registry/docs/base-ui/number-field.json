        "id": "base-ui-number-field-model-owned-state",
        "summary": "Numeric value and visible text are supplied by the consuming Foldkit model instead of hidden component state.",
        "required": true,
        "status": "accepted",
        "rationale": "Foldkit render helpers are stateless. Text entry, keyboard, and stepper handlers emit value-change facts so the application update function owns the canonical value and text."
      },
      {
        "id": "base-ui-number-field-static-origin-fixture",
