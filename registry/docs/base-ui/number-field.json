      {
        "id": "base-ui-number-field-scrub-dom-side-effects",
        "summary": "Scrub area and cursor attributes are exposed, while pointer-lock and virtual-cursor side effects are left to consumers.",
        "required": true,
        "status": "accepted",
        "rationale": "Foldkit side effects belong in Commands, not render helpers. The primitive preserves scrub parts and data attributes, and exposes pure step helpers for scrub-driven value changes."
