    "deviations": [
      {
        "id": "base-ui-combobox-model-owned-state",
        "summary": "Open state, query text, selected values, highlighted item, and highlighted chip are model-owned inputs and interactions emit typed facts instead of mutating internal component state.",
        "required": true,
        "status": "accepted",
        "rationale": "Foldkit preserves unidirectional data flow and keeps combobox state in the consuming model."
      },
      {
        "id": "base-ui-combobox-command-facing-focus-effects",
        "summary": "Focus handoff and restoration reuse the Popover command-facing helpers instead of hiding side effects inside render helpers.",
        "required": true,
        "status": "accepted",
        "rationale": "Combobox side effects must stay at Foldkit's Command boundary. The installable view remains pure and deterministic."
      },
      {
        "id": "base-ui-combobox-deterministic-placement-attributes",
        "summary": "Placement is represented through deterministic side, align, offset, collision, positioner, popup, and chips-anchor attributes without DOM measurement or collision flipping.",
        "required": true,
        "status": "accepted",
        "rationale": "Measured collision behavior belongs behind a shared measurement service, not an ad hoc Combobox render helper side effect."
      },
      {
        "id": "base-ui-combobox-local-filtering",
        "summary": "Filtering is represented as a pure local label/textValue contains match over model-owned query text.",
        "required": true,
        "status": "accepted",
        "rationale": "The local primitive preserves the origin filtering contract without importing React hooks or hiding query state outside the Foldkit model."
      }
    ]
  }
